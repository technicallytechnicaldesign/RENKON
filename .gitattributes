# Git LFS — scene / 3D / source binaries (these formats only ever appear in
# keyshot/, but tracked repo-wide for safety). Inert until a matching file is
# committed. Run `git lfs install` before adding any of these.
#
# NOTE: raster image formats (*.png, *.jpg, …) are deliberately NOT tracked
# here. This repo is SVG-first (see CLAUDE.md) — PNGs should be rare, and
# tracking them repo-wide would sweep up stray web assets. Raster *render
# outputs* are scoped to keyshot/.gitattributes instead.
*.bip   filter=lfs diff=lfs merge=lfs -text
*.ksp   filter=lfs diff=lfs merge=lfs -text
*.kmtp  filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.3dm   filter=lfs diff=lfs merge=lfs -text
*.psd   filter=lfs diff=lfs merge=lfs -text
*.exr   filter=lfs diff=lfs merge=lfs -text
*.hdr   filter=lfs diff=lfs merge=lfs -text
*.fbx   filter=lfs diff=lfs merge=lfs -text
